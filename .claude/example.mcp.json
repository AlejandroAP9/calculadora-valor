{
  "_nota": "Core activo en mcpServers. Los de _opcional NO se cargan: mueve el que necesites a mcpServers. Reemplaza los YOUR_* por tus valores en .env.local, NUNCA committees secrets.",
  "mcpServers": {
    "supabase": {
      "command": "npx",
      "args": [
        "-y",
        "@supabase/mcp-server-supabase@latest",
        "--project-ref=YOUR_SUPABASE_PROJECT_REF"
      ],
      "env": {
        "SUPABASE_ACCESS_TOKEN": "YOUR_SUPABASE_ACCESS_TOKEN"
      }
    },
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    },
    "next-devtools": {
      "command": "npx",
      "args": ["-y", "next-devtools-mcp@latest"]
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"]
    },
    "shadcn": {
      "command": "npx",
      "args": ["shadcn@latest", "mcp"]
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    }
  },
  "_opcional_mueve_a_mcpServers_si_los_usas": {
    "_research": "=== Research y contenido ===",
    "brave-search": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-brave-search"],
      "env": { "BRAVE_API_KEY": "YOUR_BRAVE_API_KEY" }
    },
    "perplexity": {
      "command": "npx",
      "args": ["-y", "@perplexity-ai/mcp-server"],
      "env": { "PERPLEXITY_API_KEY": "YOUR_PERPLEXITY_API_KEY" }
    },
    "firecrawl-mcp": {
      "command": "npx",
      "args": ["-y", "firecrawl-mcp"],
      "env": { "FIRECRAWL_API_KEY": "YOUR_FIRECRAWL_API_KEY" }
    },
    "_infra": "=== Infra y servicios ===",
    "sentry": {
      "command": "npx",
      "args": ["-y", "@sentry/mcp-server@latest"],
      "env": { "SENTRY_AUTH_TOKEN": "YOUR_SENTRY_AUTH_TOKEN" }
    },
    "resend": {
      "command": "npx",
      "args": ["-y", "resend-mcp@latest"],
      "env": { "RESEND_API_KEY": "YOUR_RESEND_API_KEY" }
    },
    "_creativo": "=== Assets creativos ===",
    "svgmaker": {
      "command": "npx",
      "args": ["@genwave/svgmaker-mcp"],
      "transport": "stdio",
      "env": { "SVGMAKER_API_KEY": "YOUR_SVGMAKER_API_KEY" }
    },
    "_automatizacion": "=== Automatizacion ===",
    "n8n-mcp": {
      "command": "docker",
      "args": [
        "run", "-i", "--rm",
        "-e", "MCP_MODE=stdio",
        "-e", "LOG_LEVEL=error",
        "-e", "DISABLE_CONSOLE_OUTPUT=true",
        "-e", "N8N_API_URL=YOUR_N8N_API_URL",
        "-e", "N8N_API_KEY=YOUR_N8N_API_KEY",
        "ghcr.io/czlonkowski/n8n-mcp:latest"
      ]
    },
    "_google": "=== Google / Firebase (rara vez con un stack Supabase) ===",
    "firebase": {
      "command": "npx",
      "args": ["-y", "firebase-tools@latest", "mcp"]
    },
    "google-workspace": {
      "command": "npx",
      "args": ["-y", "@anthropic-ai/google-workspace-mcp@latest"],
      "env": {
        "GOOGLE_CLIENT_ID": "YOUR_GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET": "YOUR_GOOGLE_CLIENT_SECRET"
      }
    },
    "_pagos": "=== Pagos: agrega el MCP de tu proveedor (ej. Mercado Pago) + sus vars (MP_ACCESS_TOKEN, MP_WEBHOOK_SECRET) en .env.local. Ver skill add-payments ===",
    "_github": "=== GitHub: agrega el MCP oficial de GitHub cuando lo necesites ==="
  }
}
